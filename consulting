  <meta name="description" content="EPICS Consulting helps households build practical resilience through structured planning across energy, water, medical, communications, records, and household continuity systems." />
  <meta name="theme-color" content="#0e1a26" />

  <style>
    :root {
      --bg: #0b1420;
      --panel: #101b2a;
      --panel-2: #162436;
      --text: #eef3f8;
      --muted: #a9b7c8;
      --line: rgba(255,255,255,0.10);
      --accent: #ff8a3d;
      --accent-2: #ffd2b8;
      --max: 1180px;
      --radius: 18px;
      --shadow: 0 12px 36px rgba(0,0,0,0.28);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top right, rgba(255,138,61,0.12), transparent 22%),
        linear-gradient(180deg, #09121c 0%, #0b1420 100%);
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    .container {
      width: min(100% - 2rem, var(--max));
      margin: 0 auto;
    }

    .section {
      padding: 5.5rem 0;
    }

    .eyebrow {
      display: inline-block;
      padding: 0.4rem 0.75rem;
      border: 1px solid rgba(255,138,61,0.22);
      border-radius: 999px;
      color: var(--accent-2);
      background: rgba(255,138,61,0.08);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(8,16,25,0.78);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      min-height: 76px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      color: #09121c;
      background: linear-gradient(135deg, var(--accent), #ffb07d);
      font-weight: 900;
      box-shadow: var(--shadow);
    }

    .brand-text {
      display: flex;
      flex-direction: column;
      line-height: 1.05;
    }

    .brand-text span:first-child {
      font-size: 0.98rem;
    }

    .brand-text span:last-child {
      font-size: 0.74rem;
      color: var(--muted);
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      color: var(--muted);
      font-weight: 600;
      font-size: 0.95rem;
    }

    .nav-links a:hover {
      color: var(--text);
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.55rem;
      min-height: 48px;
      padding: 0 1.15rem;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: transparent;
      color: var(--text);
      font-weight: 700;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .button:hover {
      transform: translateY(-1px);
      border-color: rgba(255,255,255,0.2);
    }

    .button-primary {
      background: linear-gradient(135deg, var(--accent), #ff9d61);
      color: #09121c;
      border-color: transparent;
    }

    .button-primary:hover {
      border-color: transparent;
      filter: brightness(1.04);
    }

    .button-ghost {
      background: rgba(255,255,255,0.03);
    }

    .hero {
      padding: 6rem 0 4.5rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 2rem;
      align-items: stretch;
    }

    .hero-copy h1 {
      margin: 1rem 0 1rem;
      font-size: clamp(2.4rem, 5vw, 4.7rem);
      line-height: 0.98;
      letter-spacing: -0.03em;
    }

    .hero-copy .subhead {
      max-width: 760px;
      font-size: 1.14rem;
      color: var(--muted);
      margin-bottom: 1.6rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin: 1.6rem 0 2rem;
    }

    .hero-note {
      color: var(--muted);
      font-size: 0.96rem;
      max-width: 700px;
    }

    .hero-card {
      background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 1.4rem;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 100%;
    }

    .cockpit {
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.08);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01)),
        linear-gradient(180deg, #132032, #0d1725);
      padding: 1rem;
    }

    .cockpit-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--muted);
      font-size: 0.82rem;
      margin-bottom: 0.9rem;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.35rem 0.65rem;
      border-radius: 999px;
      background: rgba(255,138,61,0.10);
      color: var(--accent-2);
      border: 1px solid rgba(255,138,61,0.22);
      font-weight: 700;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 6px rgba(255,138,61,0.10);
    }

    .score-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.8rem;
      margin-bottom: 0.9rem;
    }

    .score-box {
      border-radius: 14px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      padding: 0.85rem;
    }

    .score-box .label {
      color: var(--muted);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 0.35rem;
    }

    .score-box .value {
      font-size: 1.2rem;
      font-weight: 800;
    }

    .systems-list {
      display: grid;
      gap: 0.7rem;
      margin-top: 1rem;
    }

    .system-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.75rem;
      padding: 0.8rem 0.9rem;
      border-radius: 12px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      font-size: 0.95rem;
    }

    .system-row span:last-child {
      color: var(--accent-2);
      font-weight: 700;
    }

    .trust-bar {
      margin-top: 1.25rem;
      color: var(--muted);
      font-size: 0.92rem;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .grid-3,
    .grid-4,
    .grid-2 {
      display: grid;
      gap: 1.1rem;
    }

    .grid-2 {
      grid-template-columns: repeat(2, 1fr);
    }

    .grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }

    .grid-4 {
      grid-template-columns: repeat(4, 1fr);
    }

    .card {
      background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.5rem;
      box-shadow: var(--shadow);
    }

    .card h3,
    .card h4 {
      margin-top: 0;
      margin-bottom: 0.7rem;
      line-height: 1.2;
    }

    .card p {
      margin: 0;
      color: var(--muted);
    }

    .section-title {
      margin: 0.9rem 0 1rem;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.02;
      letter-spacing: -0.03em;
    }

    .section-intro {
      max-width: 760px;
      color: var(--muted);
      margin-bottom: 2rem;
      font-size: 1.05rem;
    }

    .problem-list,
    .service-list,
    .deliverables-list,
    .fit-list {
      margin: 0.85rem 0 0;
      padding-left: 1.15rem;
      color: var(--muted);
    }

    .problem-list li,
    .service-list li,
    .deliverables-list li,
    .fit-list li {
      margin-bottom: 0.55rem;
    }

    .stat-band {
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      background: rgba(255,255,255,0.02);
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      padding: 1.5rem 0;
    }

    .stat {
      padding: 1rem 0.5rem;
    }

    .stat strong {
      display: block;
      font-size: 1.8rem;
      line-height: 1;
      margin-bottom: 0.35rem;
      color: var(--accent-2);
    }

    .stat span {
      color: var(--muted);
      font-size: 0.95rem;
    }

    .method-card {
      position: relative;
      overflow: hidden;
    }

    .method-card::after {
      content: "";
      position: absolute;
      inset: auto -40px -40px auto;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,138,61,0.18), transparent 65%);
      pointer-events: none;
    }

    .service-tier {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      height: 100%;
    }

    .service-price {
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.03em;
    }

    .service-price small {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--muted);
    }

    .service-tag {
      display: inline-block;
      width: fit-content;
      padding: 0.35rem 0.65rem;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.10);
      color: var(--accent-2);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .quote {
      font-size: 1.15rem;
      color: var(--text);
      max-width: 860px;
    }

    .quote small {
      display: block;
      color: var(--muted);
      margin-top: 1rem;
      font-size: 0.92rem;
    }

    .cta-panel {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 1.2rem;
      align-items: stretch;
    }

    .footer {
      padding: 2rem 0 3rem;
      color: var(--muted);
      border-top: 1px solid var(--line);
    }

    .footer-grid {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .footer-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    @media (max-width: 980px) {
      .hero-grid,
      .cta-panel,
      .grid-4,
      .grid-3,
      .grid-2,
      .stat-grid {
        grid-template-columns: 1fr;
      }

      .nav {
        flex-wrap: wrap;
        padding: 0.8rem 0;
      }

      .nav-links {
        width: 100%;
        justify-content: flex-start;
        flex-wrap: wrap;
      }

      .hero {
        padding-top: 4.5rem;
      }
    }

    @media (max-width: 640px) {
      .hero-copy h1 {
        font-size: 2.5rem;
      }

      .section {
        padding: 4.25rem 0;
      }

      .button {
        width: 100%;
      }

      .hero-actions {
        flex-direction: column;
      }

      .score-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
